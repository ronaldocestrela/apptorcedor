# Copiar para `.env` na raiz do repositório para `docker compose up`.
# Não commitar `.env` com segredos reais.

# SQL Server em outro servidor (host, porta e credenciais do seu ambiente).
DATABASE_CONNECTION_STRING=Server=seu-servidor-sql,1433;Database=AppTorcedor;User Id=app;Password=trocar;TrustServerCertificate=true;

JWT_KEY=local-docker-only-change-min-32-chars-key-1
JWT_ISSUER=AppTorcedor
JWT_AUDIENCE=AppTorcedor
ADMIN_MASTER_INITIAL_PASSWORD=ChangeMe_DockerCompose1!
# Callback legacy D.4: POST /api/subscriptions/payments/callback (diferente do webhook Stripe).
PAYMENTS_WEBHOOK_SECRET=local-docker-webhook

# Pagamentos: omitir ou Mock = provedor de testes; Stripe = cartão via Checkout (PIX não suportado).
# PAYMENTS_PROVIDER=Stripe
# Se Stripe, preencha os quatro (mapeados no docker-compose para Payments__Stripe__*):
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # endpoint no Dashboard: https://<API pública>/api/webhooks/stripe
# STRIPE_SUCCESS_URL=https://app.seudominio.com.br/subscription/confirmation
# STRIPE_CANCEL_URL=https://app.seudominio.com.br/plans

# Origem da SPA no navegador (CORS). Deve bater com WEB_PORT.
CORS_ORIGIN=http://localhost:5173

# URL da API embutida no bundle Vite (navegador → host). Use a porta publicada da API.
VITE_API_URL=http://localhost:5031

# Opcional
# API_PORT=5031
# WEB_PORT=5173
