VITE_API_URL=http://localhost:5031
# Opcional: Client ID OAuth2.0 (Web) do Google para GIS no login
# VITE_GOOGLE_CLIENT_ID=
#
# Build de produção (ex.: Jenkins CD): definir VITE_API_URL como URL pública da API
# (credencial Secret text no Jenkins, ex.: vite-public-api-url) antes de `npm run build`.
