# Referência das chaves usadas em /etc/apptorcedor/api.env na VPS.
# No fluxo Jenkins + VPS (F.1), este arquivo é gerado automaticamente a cada deploy a partir do
# Jenkins Credentials — não é necessário criar nem editar manualmente api.env no servidor.
# Para desenvolvimento local ou systemd manual, copie este modelo e preencha com permissão 600.
# Não commitar valores reais.
#
# ASP.NET Core: seções com "__" no nome da variável.
#
# ConnectionStrings__DefaultConnection=Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=true;
# Jwt__Key=<minimo_32_bytes_utf8>
# Jwt__Issuer=AppTorcedor
# Jwt__Audience=AppTorcedor
# Payments__WebhookSecret=<segredo_para_callback_legacy_POST_/api/subscriptions/payments/callback>
#
# --- Stripe (cartão via Checkout; ver docs/deploy/guia-configuracao-stripe.md) ---
# Em Docker Compose use no .env: PAYMENTS_PROVIDER, STRIPE_* (equivalente a estes Payments__Stripe__*).
# Provedor: Mock (padrão) ou Stripe.
# Payments__Provider=Stripe
# Payments__Stripe__ApiKey=sk_live_...
# Payments__Stripe__WebhookSecret=whsec_...   # signing secret do endpoint no Dashboard; não confundir com Payments__WebhookSecret
# Webhook no Stripe Dashboard: https://<API pública>/api/webhooks/stripe (path fixo; sem /member/...).
# Payments__Stripe__SuccessUrl=https://app.seudominio.com.br/subscription/confirmation
# Payments__Stripe__CancelUrl=https://app.seudominio.com.br/plans
# ADMIN_MASTER_INITIAL_PASSWORD=<senha_inicial_seed>
# ASPNETCORE_ENVIRONMENT=Production
# Onde o Kestrel escuta (alinhar com reverse proxy e com APP_HEALTHCHECK_URL no Jenkins).
# ASPNETCORE_URLS=http://127.0.0.1:5031
# Google__Auth__ClientId=
# Cors__AllowedOrigins__0=https://app.seudominio.com.br
# --- Storage providers (foto de perfil, escudo do clube, logos de adversário em jogos e anexos de suporte) ---
# ProfilePhotos__Provider=Local            # Local | Cloudinary
# TeamShield__Provider=Local # Local | Cloudinary (escudo do time; pasta padrão team-shield)
# OpponentLogos__Provider=Local # Local | Cloudinary (logos de adversário; pasta padrão opponent-logos)
# BenefitOfferBanner__Provider=Local # Local | Cloudinary (banner de ofertas; pasta padrão benefit-offer-banners)
# SupportTicketAttachments__Provider=Local # Local | Cloudinary (Jenkins credential: support-ticket-attachments-provider)
# ProfilePhotos__Cloudinary__Folder=profile-photos
# TeamShield__Cloudinary__Folder=team-shield
# OpponentLogos__Cloudinary__Folder=opponent-logos
# BenefitOfferBanner__Cloudinary__Folder=benefit-offer-banners
# SupportTicketAttachments__Cloudinary__Folder=support-attachments
# Cloudinary__CloudName=                  # Jenkins credential: cloudinary-cloud-name
# Cloudinary__ApiKey=                     # Jenkins credential: cloudinary-api-key
# Cloudinary__ApiSecret=                  # Jenkins credential: cloudinary-api-secret
#
# --- E-mail via Resend (Mock = padrão; sem envio real) ---
# Email__Provider=Resend
# Email__Resend__ApiKey=re_...
# Email__Resend__FromAddress=noreply@seudominio.com.br
# Email__Resend__FromName=Sócio Torcedor
