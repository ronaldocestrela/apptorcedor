# Copie para .env na mesma pasta do .csproj e preencha (arquivo .env não é versionado).
# ASP.NET Core: use __ para chaves aninhadas (ex.: Payments__StripeSecretKey).

# --- Banco (opcional se já estiver em appsettings.Development.json) ---
# ConnectionStrings__MasterDb=Server=localhost,1433;Database=SocioTorcedor_Master;User Id=sa;Password=...;TrustServerCertificate=True
# ConnectionStrings__TenantDesignTime=Server=localhost,1433;Database=SocioTorcedor_TenantTemplate;User Id=sa;Password=...;TrustServerCertificate=True

# --- JWT e Backoffice ---
Jwt__SigningKey=sua_chave_hmac_minimo_32_caracteres_dev_only
Backoffice__ApiKey=sua_chave_backoffice

# --- Pagamentos / Stripe (conta plataforma: SaaS + operações globais) ---
Payments__StripeSecretKey=sk_test_...
Payments__StripePublishableKey=pk_test_...
Payments__StripeSaasWebhookSecret=whsec_...
Payments__StripeThinSaasWebhookSecret=whsec_...
# Webhook de sócios: Event Destination na conta do clube → POST /api/webhooks/stripe/member/{tenantId}
# — o whsec fica nas credenciais do gateway (admin do tenant), não aqui.
Payments__StripeWebhookShadowMode=false
Payments__StripeEnvironment=test
Payments__PublicAppBaseUrl=https://localhost:5173
